<% layout('layouts/Boilerplate') %>
    <div class="row">
        <!--! INFO COLUMN -->
        <div class="col-8">
            <!-- BOOTSTRAP CARD -->
            <div class="card mb-3">
                <div class="card-body">
                    <!-- IMAGE -->
                    <img class="card-img-top max-width:100%" src="<%= campground.image %>" alt="Card image cap">
                    <!-- TITLE -->
                    <h5 class="card-title">
                        <strong>
                            <%= campground.title %>
                        </strong>
                    </h5>
                    <!-- DESCRIPTION -->
                    <p class="card-text">
                        <%= campground.description %>
                    </p>
                </div>
                <!-- GROUPING ALL OF THE SUB ROWS -->
                <ul class="list-group list-group-flush">
                    <!-- LOCATION -->
                    <li class="list-group-item">
                        <%= campground.location %>
                    </li>
                    <!-- PRICE -->
                    <li class="list-group-item">
                        <strong>$<%= campground.price %></strong>/night
                    </li>
                </ul>
                <!-- SEPARATE DIV TO HOLD BUTTONS -->
                <div class="card-body">
                    <a class="card-link btn btn-info" href="/campgrounds/<%=campground._id%>/edit">
                        Edit this campground
                    </a>
                    <form class="d-inline" action="/campgrounds/<%= campground._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-danger"
                            onclick="return confirm('Are you sure you want to delete <%=campground.title %>?');">
                            Delete <%= campground.title %>?
                        </button>
                    </form>
                </div>
                <!-- FOOTER -->
                <div class="card-footer text-center text-muted">
                    <a href="/campgrounds">All Campgrounds</a>
                </div>
            </div>
        </div>


        <!--! REVIEW COLUMN -->
        <div class="col-4">
            <!--? REVIEW SECTION LOGIC -->
            <h2>Stayed here? Leave a review!</h2>
            <!-- review creation validated form -->
            <form action="/campgrounds/<%= campground._id %>/reviews" method="POST" class="mb-4 validated-form"
                novalidate>
                <!-- rating score slider -->
                <div class="mb-3">
                    <label for="rating" class="form-label">Review Score</label>
                    <input type="range" class="form-range" min="1" max="5" id="rating" name="review[rating]" required>
                </div>
                <!-- review body textarea -->
                <div class="mb-3">
                    <label for="body" class="form-label">Review</label>
                    <textarea name="review[body]" class="form-control" id="body" cols="30" rows="5" required></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <!-- submit button -->
                <button class="btn btn-success">Submit Review</button>
            </form>
            <!-- Looping through reviews and generating cards for each -->
            <% const reviewRev=campground.reviews.reverse(); %>
                <% for(let review of reviewRev) {%>
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title"><strong>Rating: <%= review.rating %>/5</strong></h5>
                            <span class="card-title"><small>Posted <%= review._id.getTimestamp().toISOString() %>
                                </small></span>
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <%= review.body %>
                            </p>
                            <form action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>?_method=DELETE"
                                method="POST">
                                <button class="btn-sm btn btn-danger">
                                    Delete Review?
                                </button>
                            </form>

                        </div>
                    </div>
                    <% } %>
        </div>
    </div>