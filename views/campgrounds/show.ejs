<% layout('layouts/Boilerplate') %>
    <div class="row">
        <div class="col-6 offset-3">
            <!-- BOOTSTRAP CARD -->
            <div class="card mb-3">
                <!-- IMAGE -->
                <img class="card-img-top" src="<%= campground.image %>" alt="Card image cap">
                <div class="card-body">
                    <!-- TITLE -->
                    <h5 class="card-title">
                        <strong>
                            <%= campground.title %>
                        </strong>
                    </h5>
                    <!-- DESCRIPTION -->
                    <p class="card-text">
                        <%= campground.description %>
                    </p>
                </div>
                <!-- GROUPING ALL OF THE SUB ROWS -->
                <ul class="list-group list-group-flush">
                    <!-- LOCATION -->
                    <li class="list-group-item">
                        <%= campground.location %>
                    </li>
                    <!-- PRICE -->
                    <li class="list-group-item">
                        <strong>$<%= campground.price %></strong>/night
                    </li>
                </ul>
                <!-- SEPERATE DIV TO HOLD BUTTONS -->
                <div class="card-body">
                    <a class="card-link btn btn-info" href="/campgrounds/<%=campground._id%>/edit">
                        Edit this campground
                    </a>
                    <form class="d-inline" action="/campgrounds/<%= campground._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-danger"
                            onclick="return confirm('Are you sure you want to delete <%=campground.title %>?');">
                            Delete <%= campground.title %>?
                        </button>
                    </form>
                </div>
                <!-- FOOTER -->
                <div class="card-footer text-center text-muted">
                    <a href="/campgrounds">All Campgrounds</a>
                </div>
            </div>
            <h2>Stayed here? Leave a review!</h2>
            <form action="" class="mb-4">
                <div class="mb-3">
                    <label for="rating" class="form-label">Review Score</label>
                    <input type="range" class="form-range" min="1" max="5" id="">
                </div>
                <div class="mb-3">
                    <label for="body" class="form-label">Review</label>
                    <textarea name="review[body]" class="form-control" id="body" cols="30" rows="5"></textarea>
                </div>
                <button class="btn btn-success">Submit Review</button>
            </form>
        </div>
    </div>