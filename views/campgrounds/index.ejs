<% layout('layouts/Boilerplate') %>

<h1>All Campgrounds</h1>
    <div>
        <a href="/campgrounds/new"><strong>Create New Campground</strong></a>
    </div>
    <ul>
        <!-- for  loop iterating thru every campground in db -->
        <!-- 'campgrounds' was passed to file in app.js  -->
        <% for (let campground of campgrounds){ %>
            <li> <a href="/campgrounds/<%= campground._id %>"><%= campground.title %></a> </li>
        <% } %>
    </ul>